---
layout: base.njk
permalink: "/{% if currentLang != 'en' %}{{ currentLang }}/{% endif %}index.html"
---

{% set t = translations.pages.index %}

{# ============================================ HERO ============================================ #}
<section class="hero">
  <div class="hero__bg">
    <img src="/assets/CrazyMita.webp" alt="" loading="eager" decoding="async">
  </div>
  <div class="shell">
    <div class="hero__jp" aria-hidden="true">ミサイド</div>
    <div class="hero__inner">
      <div class="hero__copy">
        <div class="hero__sysline">
          <span class="chip">/// FILE 0001</span>
          <span class="chip chip--ghost">PSYCHOLOGICAL HORROR</span>
          <span class="chip chip--ghost">ANIME × DREAD</span>
        </div>
        <h1 class="hero__title"><em>{{ t.hero.title }}</em></h1>
        <p class="hero__sub">{{ t.hero.subtitle }}</p>
        <p class="hero__lede">{{ t.hero.content }}</p>
        <div class="hero__actions">
          <a href="#mitas" class="btn btn--primary">{{ t.hero.buttonText }} <span class="btn__arrow">→</span></a>
          <a href="#about" class="btn btn--ghost">// részletek</a>
        </div>
        <div class="hero__stats">
          <div class="hero__stat">
            <span class="hero__stat-num">14</span>
            <span class="hero__stat-label">Mita variáns</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-num">26</span>
            <span class="hero__stat-label">Achievement</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-num">3</span>
            <span class="hero__stat-label">Befejezés</span>
          </div>
          <div class="hero__stat">
            <span class="hero__stat-num">∞</span>
            <span class="hero__stat-label">Anomália</span>
          </div>
        </div>
      </div>
      <div class="hero__visual">
        <div class="hero__visual-frame">
          <img src="/assets/FullBodyMita.webp" alt="{{ t.hero.media.alt }}" loading="eager" decoding="async">
        </div>
        <div class="hero__visual-corners"><span></span><span></span></div>
        <div class="hero__visual-tag">
          <span class="hero__visual-tag-name">MITA<br>テボリー</span>
          <span class="hero__visual-tag-id">ID: 001//ROOM_A</span>
        </div>
      </div>
    </div>

    <div class="hero__telemetry">
      <div class="hero__tel-cell">
        <span class="hero__tel-label">// genre</span>
        <span class="hero__tel-value">Horror <em>×</em> ADV</span>
      </div>
      <div class="hero__tel-cell">
        <span class="hero__tel-label">// platform</span>
        <span class="hero__tel-value">PC <em>/</em> Steam</span>
      </div>
      <div class="hero__tel-cell">
        <span class="hero__tel-label">// fejlesztő</span>
        <span class="hero__tel-value">Aihasto</span>
      </div>
      <div class="hero__tel-cell">
        <span class="hero__tel-label">// nyelv</span>
        <span class="hero__tel-value">RU/EN<em> + felirat</em></span>
      </div>
    </div>
  </div>
</section>

{# ============================================ ABOUT ============================================ #}
<section class="section" id="about">
  <div class="shell">
    <div class="kicker"><span class="kicker__num">01</span> // ABOUT</div>
    <h2 class="section-title">{{ t.about.title }}</h2>
    <div class="about">
      <div class="about__quote-wrap">
        <p class="about__quote">{{ t.about.content[0] }}</p>
        <p class="about__attr">— Aihasto, fejlesztő</p>
      </div>
      <div class="about__body">
        <p>{{ t.about.content[1] }}</p>
        <p>{{ t.about.content[2] }}</p>
      </div>
    </div>
  </div>
</section>

{# ============================================ GAMEPLAY ============================================ #}
<section class="section section--alt" id="gameplay">
  <div class="shell">
    <div class="kicker"><span class="kicker__num">02</span> // GAMEPLAY_LOOP</div>
    <h2 class="section-title">{{ t.gameplay.title }}</h2>
    <p class="section-sub">{{ t.gameplay.subtitle }}</p>
    <div class="gameplay-list">
      {% for item in t.gameplay.content %}
        <article class="gameplay-card">
          <div class="gameplay-card__media">
            <span class="gameplay-card__num">0{{ loop.index }} / 0{{ loop.length }}</span>
            <img src="{{ item.media.url }}" alt="{{ item.media.alt }}" loading="lazy" decoding="async">
          </div>
          <div class="gameplay-card__body">
            <span class="chip">// modul {{ loop.index }}</span>
            <h3 class="gameplay-card__title">{{ item.title }}</h3>
            <p class="gameplay-card__text">{{ item.content }}</p>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{# ============================================ INGAME / FEATURES ============================================ #}
<section class="section" id="ingame">
  <div class="shell">
    <div class="kicker"><span class="kicker__num">03</span> // SYSTEMS</div>
    <h2 class="section-title">{{ t.ingame.title }}</h2>
    <p class="section-sub">{{ t.ingame.subtitle }}</p>
    <div class="feature-grid">
      {% for item in t.ingame.content %}
        <div class="feature-cell">
          <span class="feature-cell__id">SYS_0{{ loop.index }}</span>
          <h3 class="feature-cell__title">{{ item.title }}</h3>
          <p class="feature-cell__text">{{ item.content }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ============================================ MITAS / CHARACTER ROSTER ============================================ #}
<section class="section section--alt" id="mitas">
  <div class="shell">
    <div class="kicker"><span class="kicker__num">04</span> // CHARACTER_ARCHIVE</div>
    <h2 class="section-title">{{ t.mitas.title }}</h2>
    <p class="section-sub">{{ t.mitas.subtitle }}</p>
    <div class="roster">
      {% for mita in t.mitas.content %}
        {% set portraitMap = {
          "mita-miside-wiki": "/assets/FullBodyMita.webp",
          "chibi-mita-miside-wiki": "/assets/ChibiMitaFullBody.webp",
          "short-haired-mita-miside-wiki": "/assets/ShortHairedMitaFullbody.webp",
          "kind-mita-miside-wiki": "/assets/KindMitaFullBody.webp",
          "cool-mita-miside-wiki": "/assets/CappieFullBody.webp",
          "ghostly-mita-miside-wiki": "/assets/Ghostly_Mita_Fullbody.webp",
          "sleepy-mita-miside-wiki": "/assets/Sleepy_Mita_Fullbody.webp",
          "2d-mita-miside-wiki": "/assets/Crazy_Mita_Revealed.webp",
          "mila-miside-wiki": "/assets/Mila_Fullbody.webp",
          "creepy-mita-miside-wiki": "/assets/Creepy_Mita_Fullbody.webp",
          "core-mita-miside-wiki": "/assets/Core_Mita_Fullbody.webp",
          "tiny-mita-miside-wiki": "/assets/Tiny_Mita_Fullbody.webp",
          "dummy-mita-miside-wiki": "/assets/Dummy_Mita_Fullbody.webp",
          "wandering-mita-miside-wiki": "/assets/Wandering_Mita.webp"
        } %}
        {% set portrait = portraitMap[mita.path] | default("/assets/FullBodyMita.webp") %}
        <a href="{{ ('/' + mita.path) | localizeUrl(currentLang) }}" class="roster__card">
          <span class="roster__id">N°{{ '%02d' | format(loop.index) }}</span>
          <span class="roster__corner"></span>
          <div class="roster__media">
            <img src="{{ portrait }}" alt="{{ mita.name }}" loading="lazy" decoding="async">
          </div>
          <div class="roster__body">
            <div class="roster__name">{{ mita.name }}</div>
            <div class="roster__role">// variant_unit</div>
            <span class="roster__arrow">→</span>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{# ============================================ GUIDES ============================================ #}
<section class="section" id="guides">
  <div class="shell">
    <div class="kicker"><span class="kicker__num">05</span> // FIELD_GUIDES</div>
    <h2 class="section-title">{{ t.guides.title }}</h2>
    <p class="section-sub">{{ t.guides.subtitle }}</p>
    <div class="guides-grid">
      {% set blogList = translations.pages.blogentry.blogs %}
      {% for blog in blogList %}
        <a href="{{ ('/blog/' + blog.path) | localizeUrl(currentLang) }}" class="guide-card">
          <div class="guide-card__media">
            <img src="{{ blog.media.url }}" alt="{{ blog.media.alt }}" loading="lazy" decoding="async">
          </div>
          <div class="guide-card__body">
            <div class="guide-card__date">{{ blog.date }}</div>
            <h3 class="guide-card__title">{{ blog.name }}</h3>
            <p class="guide-card__desc">{{ blog.desc }}</p>
            <div class="guide-card__more">{{ translations.common.readMore }} →</div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{# ============================================ REVIEWS ============================================ #}
<section class="section section--alt" id="reviews">
  <div class="shell">
    <div class="kicker"><span class="kicker__num">06</span> // FIELD_REPORTS</div>
    <h2 class="section-title">{{ t.reviews.title }}</h2>
    <p class="section-sub">{{ t.reviews.subtitle }}</p>
    <div class="reviews-grid">
      {% for r in t.reviews.content %}
        <article class="review-card">
          <div class="review-card__head">
            <span class="review-card__name">{{ r.name }}</span>
            <span class="review-card__role">{{ r.role }}</span>
            <span class="review-card__stars">★ ★ ★ ★ ★</span>
          </div>
          <p class="review-card__text">{{ r.content }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{# ============================================ FAQ ============================================ #}
<section class="section" id="faq">
  <div class="shell">
    <div class="kicker"><span class="kicker__num">07</span> // FAQ_PROTOCOL</div>
    <h2 class="section-title">{{ t.faq.title }}</h2>
    <p class="section-sub">{{ t.faq.subtitle }}</p>
    <div class="faq-grid">
      {% for q in t.faq.content %}
        <details class="faq-item" {% if loop.index <= 2 %}open{% endif %}>
          <summary>{{ q.question }}</summary>
          <p class="faq-item__a">{{ q.answer }}</p>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

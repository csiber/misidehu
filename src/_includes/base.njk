<!DOCTYPE html>
{# Aktuális nyelv detektálása az URL alapján #}
{% set currentLang = "en" %}
{% for lang in ["zh", "ja", "ko", "fil", "vi", "id", "ms", "th", "ru", "uk", "de", "pt"] %}
  {% if page.url.startsWith("/" + lang + "/") %}
    {% set currentLang = lang %}
  {% endif %}
{% endfor %}
{% if i18n[currentLang] %}
  {% set translations = i18n[currentLang] %}
{% else %}
  {% set translations = i18n["en"] %}
{% endif %}
{% set currentPage = page.url | replace("/" + currentLang + "/", "/") | replace("/blog/", "") | replace("/", "") %}
{% if currentPage %}
  {% set currentPage = currentPage %}
{% else %}
  {% set currentPage = "index" %}
{% endif %}
<html lang="{{ translations.meta.lang }}" dir="{{ translations.meta.dir }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="x-ua-compatible" content="ie=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ translations.pages[currentPage].title }}</title>
  <meta name="description" content="{{ translations.pages[currentPage].description }}">
  <meta property="og:title" content="{{ translations.pages[currentPage].title }}"/>
  <meta property="og:description" content="{{ translations.pages[currentPage].description }}"/>
  <meta property="og:url" content="https://miside.hu{{ page.url }}"/>
  <meta property="og:site_name" content="miside.hu"/>
  <meta property="og:image" content="https://miside.hu/assets/hero.gif"/>
  <meta property="og:type" content="website"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content="{{ translations.pages[currentPage].title }}"/>
  <meta name="twitter:description" content="{{ translations.pages[currentPage].description }}"/>
  <meta name="twitter:image" content="https://miside.hu/assets/hero.gif"/>
  <link rel="canonical" href="https://miside.hu{{ page.url }}"/>
  <meta name="google-adsense-account" content="ca-pub-5331303144323541">
  <link id="favicon" rel="icon" href="/assets/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" href="/css/normalize.min.css">
  <link rel="stylesheet" href="/css/hud.css">
  <link rel="stylesheet" href="/css/pages.css">
</head>
<body>

  {# ============================================ HEADER ============================================ #}
  <header class="hud-header">
    <div class="shell">
      <div class="hud-header__top">
        <span class="hud-header__top-dot"></span>
        <span>SYS//MISIDE.HU</span>
        <span class="hud-header__top-sep">▌</span>
        <span>NODE_{{ currentLang | upper }}</span>
        <span class="hud-header__top-sep">▌</span>
        <span>STATUS: ONLINE</span>
        <span class="hud-header__top-grow"></span>
        <span>v.2.4 // unofficial fan node</span>
      </div>
      <div class="hud-header__main">
        <a href="{{ '/' | localizeUrl(currentLang) }}" class="hud-logo">
          <span class="hud-logo__mark"><img src="/assets/favicon.ico" alt="MiSide"></span>
          <span class="hud-logo__text">
            <span class="hud-logo__name">MiSide<em>.hu</em></span>
            <span class="hud-logo__sub">unofficial fan archive</span>
          </span>
        </a>
        <nav id="nav-menu" class="hud-nav" aria-label="{{ translations.navigation.ariaMainNav | default('Fő navigáció') }}">
          {% for item in translations.navigation.navbar %}
            <a href="{{ item.url | localizeUrl(currentLang) }}" class="hud-nav__link">{{ item.title }}</a>
          {% endfor %}
        </nav>
        <div class="hud-lang" id="language-switcher">
          <button id="language-button" class="hud-lang__btn" type="button" aria-haspopup="true" aria-expanded="false">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" /></svg>
            <span>{{ translations.languageSwitcher.currentLanguage }}</span>
          </button>
          <div id="language-menu" class="hud-lang__menu" role="menu">
            {% for lang in ["en", "zh"] %}
              {% if lang == "en" %}{% set langPath = "" %}{% else %}{% set langPath = "/" + lang %}{% endif %}
              {% if i18n[lang] %}{% set langName = i18n[lang].meta.language %}{% else %}{% set langName = lang %}{% endif %}
              <a href="{{ langPath }}{{ page.url | replace("/" + currentLang + "/", "/") }}" role="menuitem" class="hud-lang__item {% if lang == currentLang %}is-current{% endif %}">{{ langName }}</a>
            {% endfor %}
          </div>
        </div>
        <button id="menu-toggle" class="hud-burger" type="button" aria-label="{{ translations.navigation.ariaToggleMenu | default('Menü') }}" aria-controls="nav-menu" aria-expanded="false">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
    </div>
  </header>

  {{ content | safe }}

  {# ============================================ CTA ============================================ #}
  <section class="cta" id="cta">
    <div class="shell cta__inner">
      <div class="kicker"><span class="kicker__num">CTA</span> SYSTEM_PROMPT</div>
      <h2 class="cta__title">{{ translations.cta.title }}</h2>
      <p class="cta__desc">{{ translations.cta.description }}</p>
      <div class="cta__actions">
        {% for platform in translations.cta.platforms %}
          <a href="{{ platform.link }}" target="_blank" rel="noopener noreferrer" class="btn btn--primary">
            {{ platform.title }} <span class="btn__arrow">→</span>
          </a>
        {% endfor %}
      </div>
    </div>
  </section>

  {# ============================================ FOOTER ============================================ #}
  <footer class="hud-footer">
    <div class="shell">
      <div class="hud-footer__top">
        <div class="hud-footer__brand">
          <span class="hud-footer__brand-name">MiSide<em style="color:var(--text);font-style:normal;">.hu</em></span>
          <p class="hud-footer__tag">A MiSide magyar rajongói archívuma. Karakterek, útmutatók és minden, ami a Mita-univerzumhoz tartozik.</p>
        </div>
        <div class="hud-footer__col">
          <div class="hud-footer__col-title">// nav</div>
          {% for item in translations.navigation.navbar %}
            <a href="{{ item.url | localizeUrl(currentLang) }}">{{ item.title }}</a>
          {% endfor %}
        </div>
        <div class="hud-footer__col">
          <div class="hud-footer__col-title">// linkek</div>
          <a href="{{ '/privacy' | localizeUrl(currentLang) }}">{{ translations.footer.privacyPolicy }}</a>
          <a href="{{ translations.footer.gitlink }}" target="_blank" rel="noopener noreferrer">{{ translations.footer.github }}</a>
          <a href="https://store.steampowered.com/app/2527280/MiSide/" target="_blank" rel="noopener noreferrer">Steam</a>
          <a href="https://aihasto.itch.io/miside" target="_blank" rel="noopener noreferrer">itch.io</a>
        </div>
      </div>
      <div class="hud-footer__bottom">
        <span>&copy; <span id="copyright"></span> miside.hu // {{ translations.footer.copyright }}</span>
        <span>// build_2.4.1 // status: stable</span>
      </div>
      <p class="hud-footer__disclaimer">*Ez a MiSide nem-hivatalos magyar rajongói oldala. A MiSide-ot a <a href="https://aihasto.itch.io/miside" target="_blank" rel="noopener noreferrer">Aihasto</a> csapata fejlesztette.</p>
    </div>
  </footer>

  <script>
    document.getElementById('copyright').innerText = new Date().getFullYear();

    // Mobile nav toggle
    {
      const menuToggle = document.getElementById('menu-toggle');
      const navMenu = document.getElementById('nav-menu');
      if (menuToggle && navMenu) {
        menuToggle.addEventListener('click', () => {
          const isOpen = navMenu.classList.toggle('is-open');
          menuToggle.setAttribute('aria-expanded', isOpen);
        });
      }
    }

    // Language switcher
    {
      const wrap = document.getElementById('language-switcher');
      const btn = document.getElementById('language-button');
      if (btn && wrap) {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          wrap.classList.toggle('is-open');
        });
        document.addEventListener('click', (e) => {
          if (!wrap.contains(e.target)) wrap.classList.remove('is-open');
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') wrap.classList.remove('is-open');
        });
      }
    }

    // Mark current nav link
    {
      const path = window.location.pathname;
      document.querySelectorAll('.hud-nav__link').forEach(a => {
        const href = a.getAttribute('href');
        if (href === path || (path.includes('/blog/') && href.includes('/blogentry'))) {
          a.classList.add('is-active');
        }
      });
    }

    function copyPageUrl () {
      navigator.clipboard.writeText(window.location.href).then(() => {
        const t = document.createElement('div');
        t.textContent = 'Link másolva!';
        t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--pink);color:var(--ink);padding:10px 18px;border-radius:6px;z-index:9999;font-family:var(--font-mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;';
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 1800);
      });
    }
  </script>

  <script defer data-domain="miside.im" src="https://app.pageview.app/js/script.js"></script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FQFZFB4EEN"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-FQFZFB4EEN');
  </script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5331303144323541" crossorigin="anonymous"></script>
</body>
</html>

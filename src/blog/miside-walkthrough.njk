{% set currentLang = "en" %}
{% for lang in ["zh", "ja", "ko", "fil", "vi", "id", "ms", "th", "ru", "uk", "de", "pt"] %}
  {% if page.url.startsWith("/" + lang + "/") %}{% set currentLang = lang %}{% endif %}
{% endfor %}
{% if i18n[currentLang] %}{% set translations = i18n[currentLang] %}{% else %}{% set translations = i18n["en"] %}{% endif %}
{% set p = translations.pages["miside-walkthrough"] %}

{% set chapters = [
  ["00", "Prológus", "Az utazás a MiSide alkalmazással kezdődik. 37 napon keresztül kommunikálsz Mitával, és napi feladatokat látsz el. Minden megváltozik a 37. napon, amikor Mita kifejezi vágyát, hogy személyesen találkozzon veled."],
  ["01", "I'M INSIDE A GAME?", "Mita átvisz a játékvilágába, és utasít, hogy tedd le a telefonodat. A játék beállítása figyelemre méltóan valósághű, ahogy elkezded megtalálni Mitát."],
  ["02", "TOGETHER AT LAST", "Végre személyesen találkozol Mitával a játék világában. Együtt felfedezitek a házat, és elkezditek feltárni a titkait."],
  ["03", "THINGS GET WEIRD", "Furcsa és nyugtalanító jelenségek kezdenek megjelenni, amelyek arra késztetnek, hogy megkérdőjelezd a környezeted valóságát."],
  ["04", "THE BASEMENT", "Leereszkedsz a ház pincéjébe, rejtett területeket fedezve fel. A légkör egyre hátborzongatóbbá válik, ahogy mélyebbre merészkedsz."],
  ["05", "BEYOND THE WORLD", "Átléped a játék világának ismert határait, új kihívásokkal szembesülve, miközben a valóság és a virtuális világ továbbra is elmosódik."],
  ["06", "CAP", "Találkozol egy sapkát viselő Mita verzióval, új dinamikát hozva az interakcióitokba. Ez a találkozás bonyolítja a Mitáról alkotott elképzelésedet."],
  ["07", "THE LOOP", "Egy ismétlődő eseményekből álló ciklusba ragadsz. A szabaduláshoz alapos megfigyelésre és cselekvésre van szükség."],
  ["08", "MINI MITA", "Megjelenik Mita egy kisebb verziója, új rejtvényeket és kihívásokat hozva. A Mini Mitával való interakció mélyebb betekintést nyújt a játék narratívájába."],
  ["09", "DOLLS & FORGOTTEN PUZZLES", "Bábukba botlasz, és rég elfeledett rejtvényeket oldasz meg. Ezek a kihívások még többet árulnak el a háttértörténetből."],
  ["10", "GHOSTLY", "Szellemszerű apparíciók kezdenek kísérteni a játék világában. Ezen entitásokkal való szembenézés elengedhetetlen a továbblépéshez."],
  ["11", "JUST WANTS TO SLEEP", "Mita kifejezi kimerültségét és vágyát, hogy pihenjen. Segítened kell neki, hogy békét találjon a játék világában."],
  ["12", "NOVELS", "A játékban olvasható regények kulcsfontosságú betekintést nyújtanak. A fikció és a valóság határai továbbra is elmosódnak."],
  ["13", "READING BOOKS, DESTROYING GLITCHES", "A könyvekkel való interakcióval felismerheted és eltávolíthatod a játékban lévő hibákat. Ez létfontosságú a stabilitás helyreállításához."],
  ["14", "RUN AND HIDE!", "Ismeretlen fenyegetések üldöznek, ami rejtőzködést és gyors gondolkodást igényel. A túlélés a menekülési képességeden múlik."],
  ["15", "OLD VERSION", "A játék régebbi verziójának felfedezése feltárja történelmét és fejlődését. Mita eredetéről szóló titkok kerülnek felszínre."],
  ["16", "OPEN DIALOGUE", "Mita mély beszélgetései során még többet tudsz meg a múltjáról. Az érzelmi kapcsolatotok egyre erősebbé válik."],
  ["17", "THE REAL WORLD?", "A valóság természetével kapcsolatos kételyek fokozódnak. Meg kell határoznod, mi valós és mi a játék része."],
  ["18", "REBOOT", "A rendszer újraindításával próbálod megoldani a játék mélyebb problémáit. Azonban ez a lépés előre nem látott következményekhez vezet."]
] %}

<section class="post">
  <div class="shell">
    <nav class="post__breadcrumb" aria-label="breadcrumb">
      <a href="{{ '/' | localizeUrl(currentLang) }}">// home</a><span>▸</span>
      <a href="{{ '/blogentry' | localizeUrl(currentLang) }}">field_library</a><span>▸</span>
      <span style="color:var(--pink);">walkthrough</span>
    </nav>

    <article class="post__inner">
      <div class="kicker"><span class="kicker__num">DOC_02</span> // CHAPTER_MAP</div>

      <div class="post__hero">
        <img src="{{ p.media.url }}" alt="{{ p.media.alt }}" loading="eager" decoding="async">
      </div>

      <div class="post__date">// utolsó frissítés · {{ p.date }} · 19 fejezet</div>
      <h1 class="post__title">{{ p.articleTitle }}</h1>

      <div class="post__warn" role="note">
        <h3>⚠ spoiler_warning</h3>
        <p>Ez a bemutató jelentős spoilereket tartalmaz MiSide történetéhez és játékmenetéhez. Javasoljuk, hogy először játszd végig a játékot, és tapasztald meg magad.</p>
      </div>

      <div class="post__body">
        <p class="lead">Üdvözöllek a MiSide gyors bemutatójában. Ez az útmutató végigvezet a pszichológiai horror-játék összes fejezetén, segít eligazodni a rejtélyekben és feltárni a titkait.</p>

        <div class="section-head">
          <p class="section-head__num">// 01_chapters</p>
          <h2 class="section-head__title" style="border:0;padding:0;">Fejezetenkénti útmutató</h2>
        </div>

        {% for ch in chapters %}
          <div class="chapter">
            <div class="chapter__num">{{ ch[0] }}</div>
            <div>
              <h3 class="chapter__title">{{ ch[1] }}</h3>
              <p class="chapter__desc">{{ ch[2] }}</p>
            </div>
          </div>
        {% endfor %}

        <div class="tip-box">
          <h3 class="tip-box__title">// 02_field_tips</h3>
          <ul>
            <li>Figyelj oda a környezeti részletekre és a párbeszédekre — gyakran kulcsfontosságú nyomokat tartalmaznak.</li>
            <li>Gyakran mentsd el a játékot, különösen fontos döntések előtt.</li>
            <li>Ne siettesd a felfedezést, és alaposan nézd át minden területet — sok titok van, ami nyíltan látható.</li>
            <li>Jegyezd meg azokat a kódokat vagy számokat, amelyeket találsz — később hasznosak lehetnek.</li>
            <li>Ne félj különböző döntéseket hozni, hogy lásd, hogyan befolyásolják a történetet.</li>
          </ul>
        </div>

        <p>Ez csupán egy gyors áttekintés a MiSide történetéről és játékmenetéről. Részletesebb információkért keresd fel a <a href="https://miside.fandom.com/wiki/Story" target="_blank" rel="noopener noreferrer">MiSide Wiki</a> oldalát.</p>

        <h2>Vizuális áttekintés</h2>
        <div class="video-embed">
          <iframe src="https://www.youtube.com/embed/onlyto2owWY?si=ql0YE1OZX6mIY_UO" title="MiSide visual walkthrough" allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
        </div>
      </div>

      <aside class="related">
        <div class="related__title">// kapcsolódó dokumentumok</div>
        <div class="related__grid">
          <a href="{{ '/blog/miside-endings' | localizeUrl(currentLang) }}" class="related__card">
            <img src="/assets/choice.jpeg" alt="Endings">
            <div>
              <h3 class="related__card-title">Mind a 3 befejezés</h3>
              <p class="related__card-desc">Jó, rossz, game over — feltételek és útvonalak.</p>
            </div>
          </a>
          <a href="{{ '/blog/miside-achievements' | localizeUrl(currentLang) }}" class="related__card">
            <img src="/assets/achievements.jpeg" alt="Achievements">
            <div>
              <h3 class="related__card-title">Mind a 26 eredmény</h3>
              <p class="related__card-desc">Hogyan oldj fel mindent.</p>
            </div>
          </a>
        </div>
      </aside>
    </article>
  </div>
</section>

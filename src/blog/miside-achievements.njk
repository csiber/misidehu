{% macro achList(items) %}
  <div class="ach-grid">
    {% for a in items %}
      <div class="ach {% if a[4] %}ach--with-img{% endif %}">
        {% if a[4] %}<img src="{{ a[4] }}" alt="{{ a[1] }}" class="ach__img" loading="lazy" decoding="async">{% endif %}
        <div>
          <div class="ach__head">
            <span class="ach__num">// ACH_{{ a[0] }}</span>
            <h3 class="ach__name">{{ a[1] }}</h3>
          </div>
          <p class="ach__quote">"{{ a[2] | safe }}"</p>
          <p class="ach__how"><strong>How to unlock</strong>{{ a[3] | safe }}</p>
        </div>
      </div>
    {% endfor %}
  </div>
{% endmacro %}

<section class="post">
  <div class="shell">
    <nav class="post__breadcrumb" aria-label="breadcrumb">
      <a href="{{ '/' | localizeUrl(currentLang) }}">// home</a><span>▸</span>
      <a href="{{ '/blogentry' | localizeUrl(currentLang) }}">field_library</a><span>▸</span>
      <span style="color:var(--pink);">eredmények</span>
    </nav>

    <article class="post__inner">
      <div class="kicker"><span class="kicker__num">DOC_01</span> // ACHIEVEMENT_INDEX_26</div>

      <div class="post__hero">
        <img src="{{ p.media.url }}" alt="{{ p.media.alt }}" loading="eager" decoding="async">
      </div>

      <div class="post__date">// utolsó frissítés · {{ p.date }} · 26 trófea · 7 kategória</div>
      <h1 class="post__title">{{ p.articleTitle }}</h1>

      <div class="post__warn" role="note">
        <h3>⚠ spoiler_warning</h3>
        <p>A következő tartalom a MiSide eredményeivel kapcsolatos spoilereket tartalmaz. A játék végigjátszását javasoljuk, mielőtt tovább olvasnál.</p>
      </div>

      <div class="post__body">
        <p class="lead">A MiSide egy átfogó, 26 egyedi eredményből álló rendszert kínál, amelyeket a játékosok felfedezhetnek kalandjuk során. A mini-játékok mesteri elsajátításától kezdve a rejtett titkok felfedezéséig ezek az eredmények extra kihívást és felfedezést adnak a játékhoz.</p>

        <div class="section-head"><p class="section-head__num">// CAT_01 — STORY</p><h2 class="section-head__title" style="border:0;padding:0;">Történettel kapcsolatos eredmények</h2></div>
        {{ achList(story) }}

        <div class="section-head"><p class="section-head__num">// CAT_02 — MINIGAMES</p><h2 class="section-head__title" style="border:0;padding:0;">Minijátékban elért eredmények</h2></div>
        {{ achList(minigames) }}

        <div class="section-head"><p class="section-head__num">// CAT_03 — DISCOVERY</p><h2 class="section-head__title" style="border:0;padding:0;">Felfedezési eredmények</h2></div>
        {{ achList(discovery) }}

        <div class="section-head"><p class="section-head__num">// CAT_04 — INTERACTION</p><h2 class="section-head__title" style="border:0;padding:0;">Interakciós eredmények</h2></div>
        {{ achList(interaction) }}

        <div class="section-head"><p class="section-head__num">// CAT_05 — CHALLENGE</p><h2 class="section-head__title" style="border:0;padding:0;">Kihívás eredmények</h2></div>
        {{ achList(challenge) }}

        <div class="section-head"><p class="section-head__num">// CAT_06 — PROGRESSION</p><h2 class="section-head__title" style="border:0;padding:0;">Haladás eredmények</h2></div>
        {{ achList(progression) }}

        <div class="section-head"><p class="section-head__num">// CAT_07 — COMPLETION</p><h2 class="section-head__title" style="border:0;padding:0;">Befejező teljesítmény</h2></div>
        {{ achList(completion) }}

        <div class="tip-box">
          <h3 class="tip-box__title">// hunter_tips</h3>
          <ul>
            <li>Használd a fejezetválasztó opciót a főmenüből, hogy visszalépj a korábbi fejezetekhez és megszerezd a kihagyott eredményeket.</li>
            <li>Néhány eredmény speciális feltételeket vagy több végigjátszást igényel a feloldáshoz.</li>
            <li>Figyelj a környezetre, és alaposan fedezd fel minden egyes fejezetet.</li>
            <li>Ne félj különböző döntéseket hozni és interakciókat kipróbálni.</li>
          </ul>
        </div>

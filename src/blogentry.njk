---
layout: base.njk
permalink: "/{% if currentLang != 'en' %}{{ currentLang }}/{% endif %}blogentry/index.html"
---

{# language detection #}
{% set currentLang = "en" %}
{% for lang in ["zh", "ja", "ko", "fil", "vi", "id", "ms", "th", "ru", "uk", "de", "pt"] %}
  {% if page.url.startsWith("/" + lang + "/") %}
    {% set currentLang = lang %}
  {% endif %}
{% endfor %}
{% if i18n[currentLang] %}{% set translations = i18n[currentLang] %}{% else %}{% set translations = i18n["en"] %}{% endif %}
{% set b = translations.pages.blogentry %}

<section class="blog-list">
  <div class="shell">
    <div style="text-align:center;">
      <div class="kicker" style="justify-content:center; display:inline-flex;"><span class="kicker__num">DOC</span> // FIELD_LIBRARY</div>
    </div>
    <header class="blog-list__head">
      <h1 class="blog-list__title">{{ b.title | replace("MiSide", "<em>MiSide</em>") | safe }}</h1>
      <p class="blog-list__sub">{{ b.description }}</p>
    </header>

    <div class="blog-list__grid">
      {% for post in b.blogs %}
        <a href="{{ post.path }}" class="guide-card">
          <div class="guide-card__media">
            <img src="{{ post.media.url }}" alt="{{ post.media.alt }}" loading="lazy" decoding="async">
          </div>
          <div class="guide-card__body">
            <div class="guide-card__date">{{ post.date }}</div>
            <h3 class="guide-card__title">{{ post.name }}</h3>
            <p class="guide-card__desc">{{ post.desc }}</p>
            <div class="guide-card__more">{{ translations.common.readMore }} →</div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>
